# gitignore file for ZinPass project

# 忽略以下三个目录及其目录下的所有子目录和文件
/client_desktop/generate/**
/control/generate/**
/service/generate/**

# 忽略所有 build 目录
build/

# 忽略以下测试文件
data/zinpass.db
data/zinpass.db.backup
data/test.db
data/test.db.backup

# 忽略以下扩展名的文件
*.o
*.obj
*.tmp
*.exe
*.dll
*.so
*.a
*.lib
*.tar.gz
*.zip
*.7z

# 编辑器/IDE 文件
.idea/
.vscode/
*.swp


