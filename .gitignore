# gitignore file for ZinPass project

# 忽略以下三个目录及其目录下的所有子目录和文件
/client-desktop/generate/**
/control/generate/**
/service/generate/**

# 忽略所有 build 目录
build/

# 忽略以下测试文件
data/zinpass.db

# 忽略所有 .o 文件
*.o
*.tmp
*.exe
*.dll
*.so
*.a
*.lib

# 编辑器/IDE 文件
.idea/
.vscode/
*.swp


